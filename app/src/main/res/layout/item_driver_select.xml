<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_driver"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#1A112D4E"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:checkedIconTint="@color/accent_teal"
    app:strokeColor="@color/accent_teal"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Team colour strip -->
        <View
            android:id="@+id/team_color_strip"
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="#FFFFFF" />

        <!-- Driver 3-letter code -->
        <TextView
            android:id="@+id/tv_driver_code"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="VER"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <!-- Name + team -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:id="@+id/tv_driver_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Max Verstappen"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_driver_team"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Red Bull"
                android:textColor="@color/accent_teal"
                android:textSize="11sp"
                android:layout_marginTop="1dp" />

        </LinearLayout>

        <!-- Checkmark -->
        <TextView
            android:id="@+id/tv_checkmark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textColor="@color/accent_teal"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>