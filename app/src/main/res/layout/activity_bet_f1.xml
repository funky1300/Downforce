<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#112D4E"
    android:orientation="vertical">

    <!-- Title Bar -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3F72AF"
        android:padding="24dp"
        android:text="🏁 BET F1"
        android:textColor="#DBE2EF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Points Balance Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/rounded_card_bg"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOUR POINTS"
                        android:textColor="#DBE2EF"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_points"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1000 🪙"
                        android:textColor="#F9F7F7"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVE BETS"
                        android:textColor="#DBE2EF"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_bet_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 🎲"
                        android:textColor="#F9F7F7"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- ═══════════════════════════════════ -->
            <!--        SECTION 1 - NEXT RACE        -->
            <!-- ═══════════════════════════════════ -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="🏎️  NEXT RACE — TOP 10"
                android:textColor="#DBE2EF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Pick where a driver will finish in the next Grand Prix"
                android:textColor="#3F72AF"
                android:textSize="12sp" />

            <!-- Next Race Bet Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/rounded_card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Driver"
                    android:textColor="#DBE2EF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinner_race_driver"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:background="#112D4E"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Predicted finish position"
                    android:textColor="#DBE2EF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinner_race_position"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:background="#112D4E"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Points to bet"
                    android:textColor="#DBE2EF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edit_race_bet_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="#112D4E"
                    android:hint="Enter points..."
                    android:inputType="number"
                    android:padding="12dp"
                    android:textColor="#F9F7F7"
                    android:textColorHint="#3F72AF"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_place_race_bet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#DBE2EF"
                    android:text="BET ON RACE"
                    android:textColor="#112D4E"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- My Race Bets list -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="MY RACE BETS"
                android:textColor="#F9F7F7"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/race_bets_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_no_race_bets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_card_bg"
                    android:gravity="center"
                    android:padding="20dp"
                    android:text="No race bets yet 🏎️"
                    android:textColor="#DBE2EF"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginBottom="24dp"
                android:background="#3F72AF" />

            <!-- ══════════════════════════════════════ -->
            <!--      SECTION 2 - CHAMPIONSHIP          -->
            <!-- ══════════════════════════════════════ -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="🏆  CHAMPIONSHIP BETS"
                android:textColor="#DBE2EF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Who will win the season? Pays out at the end of the year"
                android:textColor="#3F72AF"
                android:textSize="12sp" />

            <!-- Championship Bet Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/rounded_card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Championship"
                    android:textColor="#DBE2EF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinner_championship_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:background="#112D4E"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Predicted champion"
                    android:textColor="#DBE2EF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinner_championship_winner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:background="#112D4E"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Points to bet"
                    android:textColor="#DBE2EF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edit_champ_bet_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="#112D4E"
                    android:hint="Enter points..."
                    android:inputType="number"
                    android:padding="12dp"
                    android:textColor="#F9F7F7"
                    android:textColorHint="#3F72AF"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_place_champ_bet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#DBE2EF"
                    android:text="BET ON CHAMPIONSHIP"
                    android:textColor="#112D4E"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- My Championship Bets list -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="MY CHAMPIONSHIP BETS"
                android:textColor="#F9F7F7"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/champ_bets_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_no_champ_bets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_card_bg"
                    android:gravity="center"
                    android:padding="20dp"
                    android:text="No championship bets yet 🏆"
                    android:textColor="#DBE2EF"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>
    </FrameLayout>

</LinearLayout>