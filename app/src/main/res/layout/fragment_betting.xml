<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ══════════════════════════════════════ -->
        <!--           BALANCE HEADER               -->
        <!-- ══════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/secondary_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AVAILABLE POINTS"
                        android:textColor="@color/accent_teal"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_balance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1000 pts"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#40DBE2EF"
                    android:layout_marginHorizontal="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVE BETS"
                        android:textColor="@color/accent_teal"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_active_bets"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 active"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════ -->
        <!--       SECTION 1 — RACE TOP 10          -->
        <!-- ══════════════════════════════════════ -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏎️  NEXT RACE — TOP 10 PREDICTION"
            android:textColor="@color/accent_teal"
            android:textSize="13sp"
            android:letterSpacing="0.08"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select exactly 10 drivers you think will finish in the points"
            android:textColor="#90DBE2EF"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <!-- Selection counter pill -->
        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="0 / 10 drivers selected"
            android:textColor="@color/accent_teal"
            android:textSize="12sp"
            android:alpha="0.6"
            android:layout_marginBottom="8dp" />

        <!-- Driver list card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/secondary_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_race_drivers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:nestedScrollingEnabled="false" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Race bet amount + button -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/secondary_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Points to wager"
                    app:boxBackgroundColor="#1A000000"
                    app:boxStrokeColor="@color/accent_teal"
                    app:hintTextColor="@color/accent_teal"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_race_bet_amount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_place_race_bet"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:text="PLACE RACE BET"
                    android:textColor="@color/primary_dark"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    app:backgroundTint="@color/accent_teal"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════ -->
        <!--   SECTION 2 — CHAMPIONSHIP BET         -->
        <!-- ══════════════════════════════════════ -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆  CHAMPIONSHIP BET"
            android:textColor="@color/accent_teal"
            android:textSize="13sp"
            android:letterSpacing="0.08"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Who will win the 2026 Drivers' World Championship?"
            android:textColor="#90DBE2EF"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_champ_selected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="Select your champion"
            android:textColor="@color/accent_teal"
            android:textSize="12sp"
            android:alpha="0.6"
            android:layout_marginBottom="8dp" />

        <!-- Championship driver list -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/secondary_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_champ_drivers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:nestedScrollingEnabled="false" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Championship bet amount + button -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/secondary_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Points to wager"
                    app:boxBackgroundColor="#1A000000"
                    app:boxStrokeColor="@color/accent_teal"
                    app:hintTextColor="@color/accent_teal"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_champ_bet_amount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_place_champ_bet"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:text="PLACE CHAMPIONSHIP BET"
                    android:textColor="@color/primary_dark"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    app:backgroundTint="@color/accent_teal"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════════════ -->
        <!--          MY ACTIVE BETS                -->
        <!-- ══════════════════════════════════════ -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋  MY ACTIVE BETS"
            android:textColor="@color/accent_teal"
            android:textSize="13sp"
            android:letterSpacing="0.08"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_no_bets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card_bg"
            android:gravity="center"
            android:padding="24dp"
            android:text="No bets placed yet. Go on, take a risk! 🎲"
            android:textColor="#90DBE2EF"
            android:textSize="13sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_active_bets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>